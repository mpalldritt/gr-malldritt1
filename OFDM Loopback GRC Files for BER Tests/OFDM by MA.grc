options:
  parameters:
    author: MA
    catch_exceptions: 'True'
    category: Custom
    cmake_opt: ''
    comment: "Notes by MA: this flow graph was created in March \nto try and find\
      \ a soultion for OFDM using float instead \nof complex audio sink. i used virtual\
      \ pads which have been \nreplaced by vitual source/sink. This has resolved one\
      \ problem \nbut created an issue with the following error. \nheader_payload_demux\
      \ :info: Detected a packet larger than max frame size (110 symbols)"
    copyright: ''
    description: 'OFDM file transfer '
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: OFDM_by_MA
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: OFDM_by_MA
    window_size: 1280, 1024
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [16, 20.0]
    rotation: 0
    state: enabled

